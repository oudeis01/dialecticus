# Copy this file to .env and fill in your keys. `.env` is gitignored.
# dialecticus loads .env automatically at startup.

# Required for the OpenRouter free-model config (personas.openrouter-free.yaml).
OPENROUTER_API_KEY=

# Required for the OpenCode Zen free-model config (personas.zen-free.yaml).
OPENCODE_API_KEY=

# Only needed if a persona uses provider: anthropic (the native Messages API).
ANTHROPIC_API_KEY=

ZAI_API_KEY=
